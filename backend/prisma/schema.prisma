generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  role          String         // 'manufacturer', 'regulator', 'pharmacy'
  org           String         // MSP ID e.g. 'VyrobcaMSP'
  notifications Notification[]

  @@index([org])
  @@index([role])
}

model DrugCatalog {
  id                Int     @id @default(autoincrement())
  name              String  @unique
  composition       String  @db.Text
  recommendedDosage String  @db.Text
  intakeInfo        String? @db.Text
  metadata          String? @db.Text
  files             File[]
}

model File {
  id             Int           @id @default(autoincrement())
  url            String
  cid            String?
  name           String
  type           String
  size           Int
  category       String        // 'GALLERY', 'LEAFLET', 'OTHER'
  drugCatalogId  Int?
  drugCatalog    DrugCatalog?  @relation(fields: [drugCatalogId], references: [id])
  orderRequestId Int?
  orderRequest   OrderRequest? @relation(fields: [orderRequestId], references: [id])
  createdAt      DateTime      @default(now())

  @@index([drugCatalogId])
  @@index([orderRequestId])
}

model OrderRequest {
  id              Int           @id @default(autoincrement())
  requestId       String        @unique
  drugId          String
  drugName        String
  manufacturerOrg String
  pharmacyOrg     String
  quantity        Float
  unit            String
  status          String        @default("PENDING") // PENDING, OFFER_MADE, APPROVED, REJECTED, ORDERED, FULFILLED
  rejectionReason String?       @db.Text
  files           File[]
  fulfillments    Fulfillment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([manufacturerOrg])
  @@index([pharmacyOrg])
  @@index([status])
  @@index([drugId])
}

model Fulfillment {
  id             Int          @id @default(autoincrement())
  orderRequestId Int
  orderRequest   OrderRequest @relation(fields: [orderRequestId], references: [id])
  batchID        String
  quantity       Float
  createdAt      DateTime     @default(now())

  @@index([orderRequestId])
  @@index([batchID])
}

model Drug {
  id           Int      @id @default(autoincrement())
  batchID      String   @unique
  drugID       String?
  drugName     String
  manufacturer String
  ownerOrg     String
  quantity     Float    @default(0)
  unit         String   @default("ks")
  expiryDate   String
  status       String
  price        Float?
  priceOffer   Float?
  metadata     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerOrg])
  @@index([status])
  @@index([manufacturer])
  @@index([drugID])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  batchID   String?
  userID    Int
  timestamp DateTime @default(now())
  details   String?  @db.Text

  @@index([userID])
  @@index([batchID])
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   // 'URGENT_RECALL', 'INFO', 'DELIVERY'
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model PriceOffer {
  id              Int      @id @default(autoincrement())
  batchID         String
  manufacturerOrg String
  pharmacyOrg     String
  price           Float
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  @@index([batchID])
  @@index([manufacturerOrg])
  @@index([pharmacyOrg])
}
